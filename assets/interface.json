{
    "interface_version": 2,
    "name": "MaaGC",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaGC!",
    "github": "https://github.com/MaaXYZ/MAAGC",
    "version": "1.0.0",
    "mirrorchyan_rid": "MaaGC",
    "mirrorchyan_multiplatform": false,
    "controller": [
        {
            "name": "ADB",
            "type": "Adb",
            "label": "模拟器",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "agent": {
        "child_exec": "./python/python.exe",
        "child_args": [
            "-u",
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "GameStartUp",
            "doc": [
                "### 启动游戏",
                "",
                "启动游戏客户端，完成登录流程。",
                "",
                "**功能说明：**",
                "- 自动启动游戏",
                "- 处理登录界面",
                "- 进入主界面"
            ]
        },
        {
            "name": "每日礼包和密令",
            "entry": "Auto_DailyTask",
            "option": [
                "DailyTaskSubTaskSwitch"
            ],
            "doc": [
                "### 每日礼包和密令",
                "",
                "每日任务综合管理，包括礼包领取、市场操作、商城购物和悬赏令领取。",
                "",
                "**功能说明：**",
                "- 自动处理每日礼包和密令",
                "- 自动进入市场购买折扣物品",
                "- 自动进入商城领取免费礼包",
                "- 自动进入悬赏令界面领取奖励（包含女王、王族令牌）",
                "- 完成后返回大地图",
                "",
                "**使用场景：**",
                "- 每日登录后自动处理各项日常任务",
                "- 定期清理和领取游戏内各项奖励"
            ]
        },
        {
            "name": "推月",
            "entry": "Auto_FightTask",
            "doc": [
                "### 推月（月度任务）",
                "",
                "自动执行月度战斗任务。",
                "",
                "**功能说明：**",
                "- 自动处理月度事件",
                "- 执行战斗任务",
                "- 处理节日活动"
            ]
        },
        {
            "name": "推年",
            "entry": "Auto_YearlyTask",
            "doc": [
                "### 推年（年度任务）",
                "",
                "自动执行年度任务流程。",
                "",
                "**功能说明：**",
                "- 按月份处理全年事件",
                "- 自动推进游戏时间",
                "- 处理年度特殊事件"
            ]
        },
        {
            "name": "自动孩子取名字——小工具",
            "entry": "Auto_PannelCheck",
            "doc": [
                "### 自动孩子取名字",
                "",
                "识别子项信息并自动生成名字的小工具。",
                "",
                "**功能说明：**",
                "- 识别父母信息（姓名、爵位、佣兵团）",
                "- 识别潜力面板（六维属性：力量、体质、技巧、感知、敏捷、意志）",
                "- 识别血脉面板（血统名称及百分比）",
                "- 识别特性面板（特性列表）",
                "- 自动生成子孙名字",
                "",
                "**命名规则：**",
                "- 格式：`最高属性 + 次高属性 + 特性 + 爵位`",
                "- 示例：`力 ss 技 ss 太科公`",
                "",
                "**属性等级：**",
                "- SS: > 0.93",
                "- S: 0.74-0.93",
                "- A: 0.55-0.74",
                "- B: 0.35-0.55",
                "- C: 0.20-0.35",
                "- D: 0.10-0.20",
                "- E: < 0.10",
                "",
                "**使用场景：**",
                "- 佣兵生娃事件后自动触发",
                "- 手动执行进行孩子命名"
            ]
        },
        {
            "name": "自动相亲",
            "entry": "Auto_MarryTask",
            "doc": [
                "### 自动相亲",
                "",
                "自动处理相亲事件，匹配高血统姓名。",
                "",
                "**功能说明：**",
                "- 自动进入联姻大厅",
                "- 检测相亲对象数量和回信数量",
                "- 遍历所有可相亲对象",
                "- 识别角色血统信息（潜力、血脉、特性）",
                "- 根据血统匹配国家和种族",
                "- 在姓名库中查找匹配的高血统姓名",
                "- 自动确认相亲或切换下一个对象",
                "",
                "**配置说明：**",
                "- high_blood_names.json: 高血统姓名表",
                "- 可通过 child_alert_enabled 参数开启好苗子提醒"
            ]
        }
    ],
    "option": {
        "DailyTaskSubTaskSwitch": {
            "type": "checkbox",
            "description": "是否自动处理每日任务",
            "cases": [
                {
                    "name": "购买市场折扣物品",
                    "description": "是否自动购买市场折扣物品",
                    "pipeline_override": {
                        "BigMapMarket": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "商城免费礼包",
                    "description": "是否自动购买商城免费礼包",
                    "pipeline_override": {
                        "BigMapMall": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "悬赏令领取",
                    "description": "是否自动领取悬赏令",
                    "pipeline_override": {
                        "BigMapRewardToken": {
                            "enabled": true
                        }
                    }
                }
            ],
            "default_case": [
                "市场折扣物品",
                "商城免费礼包",
                "悬赏令领取"
            ]
        }
    }
}