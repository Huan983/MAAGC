{
    "interface_version": 2,
    "name": "MaaGC",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaGC!",
    "github": "https://github.com/MaaXYZ/MAAGC",
    "version": "1.0.0",
    "mirrorchyan_rid": "MaaGC",
    "mirrorchyan_multiplatform": false,
    "controller": [
        {
            "name": "ADB",
            "type": "Adb",
            "label": "模拟器",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "agent": {
        "child_exec": "./python/python.exe",
        "child_args": [
            "-u",
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "启动游戏",
            "entry": "GameStartUp",
            "description": "启动游戏客户端并完成登录流程"
        },
        {
            "name": "每日礼包和密令",
            "entry": "Auto_DailyTask",
            "option": [
                "DailyTaskSubTaskSwitch"
            ],
            "description": "自动处理每日礼包、市场折扣、商城礼包和悬赏令领取"
        },
        {
            "name": "推年计划",
            "entry": "Auto_YearlyTask",
            "option": [
                "开启5月城堡相亲",
                "开启好娃提醒",
                "选择刷取任务国家",
                "相亲模式",
                "选择年度任务月份数",
                "自定义任务黑名单"
            ],
            "description": "自动执行年度任务流程并推进游戏时间"
        },
        {
            "name": "自动孩子取名字——小工具",
            "entry": "Auto_PannelCheck",
            "doc": [
                "### 自动孩子取名字",
                "",
                "识别子项信息并自动生成名字的小工具。",
                "",
                "**功能说明：**",
                "- 识别父母信息（姓名、爵位、佣兵团）",
                "- 识别潜力面板（六维属性：力量、体质、技巧、感知、敏捷、意志）",
                "- 识别血脉面板（血统名称及百分比）",
                "- 识别特性面板（特性列表）",
                "- 自动生成子孙名字",
                "",
                "**命名规则：**",
                "- 格式：`最高属性 + 次高属性 + 特性 + 爵位`",
                "- 示例：`力 ss 技 ss 太科公`",
                "",
                "**属性等级：**",
                "- SS: > 0.93",
                "- S: 0.74-0.93",
                "- A: 0.55-0.74",
                "- B: 0.35-0.55",
                "- C: 0.20-0.35",
                "- D: 0.10-0.20",
                "- E: < 0.10",
                "",
                "**使用场景：**",
                "- 佣兵生娃事件后自动触发",
                "- 手动执行进行孩子命名"
            ],
            "description": "识别孩子信息并自动生成名字的工具"
        },
        {
            "name": "自动相亲",
            "entry": "Auto_MarryTask",
            "doc": [
                "### 自动相亲",
                "",
                "自动处理相亲事件，匹配高血统姓名。",
                "",
                "**功能说明：**",
                "- 自动进入联姻大厅",
                "- 检测相亲对象数量和回信数量",
                "- 遍历所有可相亲对象",
                "- 识别角色血统信息（潜力、血脉、特性）",
                "- 根据血统匹配国家和种族",
                "- 在姓名库中查找匹配的高血统姓名",
                "- 自动确认相亲或切换下一个对象",
                "",
                "**配置说明：**",
                "- high_blood_names.json: 高血统姓名表",
                "- 可通过 child_alert_enabled 参数开启好苗子提醒"
            ],
            "description": "自动处理相亲事件并匹配高血统姓名"
        }
    ],
    "option": {
        "DailyTaskSubTaskSwitch": {
            "type": "checkbox",
            "description": "是否自动处理每日任务",
            "cases": [
                {
                    "name": "购买市场折扣物品",
                    "description": "是否自动购买市场折扣物品",
                    "pipeline_override": {
                        "BigMapMarket": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "商城免费礼包",
                    "description": "是否自动购买商城免费礼包",
                    "pipeline_override": {
                        "BigMapMall": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "悬赏令领取",
                    "description": "是否自动领取悬赏令",
                    "pipeline_override": {
                        "BigMapRewardToken": {
                            "enabled": true
                        }
                    }
                }
            ],
            "default_case": [
                "市场折扣物品",
                "商城免费礼包",
                "悬赏令领取"
            ]
        },
        "开启5月城堡相亲": {
            "type": "switch",
            "description": "是否开启5月自动相亲",
            "cases": [
                {
                    "name": "Yes",
                    "description": "开启5月城堡相亲",
                    "pipeline_override": {
                        "Flag_EnableMarryTask": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "description": "关闭5月城堡相亲",
                    "pipeline_override": {
                        "Flag_EnableMarryTask": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "开启好娃提醒": {
            "type": "checkbox",
            "description": "是否开启好娃提醒,提醒时弹窗并结束任务",
            "cases": [
                {
                    "name": "科内塔之怒",
                    "description": "纯血科内塔+ss技巧+s力量+敏/意0.3以上才提醒.",
                    "pipeline_override": {
                        "检测_科内塔之怒": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "太阳+科内塔之怒",
                    "description": "太阳之子+科内塔+ss技巧+s力量+敏/意0.3以上才提醒.",
                    "pipeline_override": {
                        "检测_太阳+科内塔之怒": {
                            "enabled": true
                        }
                    }
                }
            ],
            "default_case": [
                "科内塔之怒",
                "太阳+科内塔之怒"
            ]
        },
        "选择刷取任务国家": {
            "type": "select",
            "description": "选择要刷取任务的目标城市",
            "default_case": "雄月城",
            "cases": [
                {
                    "name": "王座堡",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "王座堡"
                        }
                    }
                },
                {
                    "name": "圣盾堡",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "圣盾堡"
                        }
                    }
                },
                {
                    "name": "雄月城",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "雄月城"
                        }
                    }
                },
                {
                    "name": "翠庭",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "翠庭"
                        }
                    }
                },
                {
                    "name": "银风堡",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "银风堡"
                        }
                    }
                },
                {
                    "name": "暮角城",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "暮角城"
                        }
                    }
                },
                {
                    "name": "巴索罗姆",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "巴索罗姆"
                        }
                    }
                },
                {
                    "name": "奥克尼尼",
                    "pipeline_override": {
                        "EnterCity": {
                            "expected": "奥克尼尼"
                        }
                    }
                }
            ]
        },
        "选择年度任务月份数": {
            "type": "select",
            "description": "选择年度任务的执行月份数",
            "default_case": "12个月",
            "cases": [
                {
                    "name": "6个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "6"
                            ]
                        }
                    }
                },
                {
                    "name": "12个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "12"
                            ]
                        }
                    }
                },
                {
                    "name": "24个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "24"
                            ]
                        }
                    }
                },
                {
                    "name": "36个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "36"
                            ]
                        }
                    }
                },
                {
                    "name": "60个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "60"
                            ]
                        }
                    }
                },
                {
                    "name": "120个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "120"
                            ]
                        }
                    }
                },
                {
                    "name": "240个月",
                    "pipeline_override": {
                        "YearlyTaskMonths": {
                            "expected": [
                                "240"
                            ]
                        }
                    }
                }
            ]
        },
        "自定义任务黑名单": {
            "type": "input",
            "label": "自定义任务黑名单",
            "description": "输入要屏蔽的任务名称，被屏蔽的任务在年度任务中会自动跳过。\n\n**注意：**\n- 输入的任务名称会保存到本地文件 `assets/table/task_blacklist.json`\n- 重启后仍然生效，无需重新输入\n- 如需删除，请手动编辑 `assets/table/task_blacklist.json` 文件，从 blacklist 数组中移除对应名称",
            "inputs": [
                {
                    "name": "任务名称",
                    "description": "要屏蔽的任务名称（单个任务名称）",
                    "default": "",
                    "pipeline_type": "string",
                    "verify": "^[^,，]+$",
                    "pattern_msg": "任务名称不能包含逗号，请输入单个任务名称"
                }
            ],
            "pipeline_override": {
                "CustomTaskBlacklist": {
                    "expected": [
                        "{任务名称}"
                    ]
                }
            }
        },
        "相亲模式": {
            "type": "select",
            "description": "选择要刷取任务的目标城市",
            "default_case": "姓名相亲",
            "cases": [
                {
                    "name": "姓名相亲",
                    "pipeline_override": {
                        "MarryModeSelect": {
                            "expected": "high_blood"
                        }
                    }
                },
                {
                    "name": "聊天相亲",
                    "pipeline_override": {
                        "MarryModeSelect": {
                            "expected": "trait"
                        }
                    }
                }
            ]
        }
    }
}